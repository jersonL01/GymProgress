generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())

  profile         Profile?
  exercises       Exercise[]
  entries         Entry[]
  routines        Routine[]
  workoutSessions WorkoutSession[]
  accounts        Account[]
  sessions        Session[]
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  weightKg       Float?
  heightCm       Float?
  age            Int?
  goal           String?
  caloriesTarget Int?
  proteinTarget  Int?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exercise {
  id                 String   @id @default(cuid())
  externalId         String?  @unique
  name               String
  nameEs             String?
  category           String?
  categoryEs         String?
  force              String?
  forceEs            String?
  level              String?
  levelEs            String?
  mechanic           String?
  mechanicEs         String?
  equipment          String?
  equipmentEs        String?
  primaryMuscles     String[]
  primaryMusclesEs   String[]
  secondaryMuscles   String[]
  secondaryMusclesEs String[]
  instructions       String[]
  instructionsEs     String[]
  images             String[]

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  entries                 Entry[]
  routineExercises        RoutineExercise[]
  workoutSessionExercises WorkoutSessionExercise[]

  @@index([userId])
  @@index([name])
  @@index([nameEs])
}

model Entry {
  id       String   @id @default(cuid())
  date     DateTime
  weightKg Float
  reps     Int
  sets     Int
  notes    String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([exerciseId])
  @@index([date])
  @@index([userId, date])
}

model Routine {
  id              String            @id @default(cuid())
  name            String
  dayLabel        String?
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises       RoutineExercise[]
  workoutSessions WorkoutSession[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
}

model RoutineExercise {
  id        String  @id @default(cuid())
  routineId String
  routine   Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  notes       String?
  restSeconds Int?
  sortOrder   Int     @default(0)

  sets      RoutineSet[]
  createdAt DateTime     @default(now())

  @@index([routineId])
  @@index([exerciseId])
}

model RoutineSet {
  id                String          @id @default(cuid())
  routineExerciseId String
  routineExercise   RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)

  setNumber         Int
  targetKg          Float?
  targetReps        Int?
  completed         Boolean         @default(false)

  createdAt         DateTime        @default(now())

  @@index([routineExerciseId])
}

model WorkoutSession {
  id        String  @id @default(cuid())
  routineId String
  routine   Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int       @default(0)
  status      String    @default("in_progress")

  exercises WorkoutSessionExercise[]

  createdAt DateTime @default(now())

  @@index([routineId])
  @@index([userId])
}

model WorkoutSessionExercise {
  id               String         @id @default(cuid())
  workoutSessionId String
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  nameSnapshot String
  notes        String?
  restSeconds  Int?
  sortOrder    Int     @default(0)

  sets WorkoutSessionSet[]

  createdAt DateTime @default(now())

  @@index([workoutSessionId])
  @@index([exerciseId])
}

model WorkoutSessionSet {
  id                       String                 @id @default(cuid())
  workoutSessionExerciseId String
  workoutSessionExercise   WorkoutSessionExercise @relation(fields: [workoutSessionExerciseId], references: [id], onDelete: Cascade)

  setNumber    Int
  previousKg   Float?
  previousReps Int?
  actualKg     Float?
  actualReps   Int?
  completed    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([workoutSessionExerciseId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
